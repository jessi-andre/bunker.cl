# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_STARTER=price_xxx
STRIPE_PRICE_ID_PRO=price_xxx
STRIPE_PRICE_ID_ELITE=price_xxx

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxxx

# Base URL de la app (en local y producción)
APP_BASE_URL=http://localhost:3000

# Sesiones
# Tiempo de vida de sesión en segundos (default: 7 días)
SESSION_MAX_AGE_SECONDS=604800
# Umbral para renovación sliding (default: 6 horas)
SESSION_SLIDING_THRESHOLD_SECONDS=21600
# Máximo absoluto de sesión en segundos (default: 30 días)
SESSION_ABSOLUTE_MAX_SECONDS=2592000
# Validación de User-Agent: "soft" (warn) | "hard" (invalidate)
SESSION_USER_AGENT_MODE=soft
# Si "true", invalida sesiones previas al hacer login
LOGIN_INVALIDATE_PREVIOUS_SESSIONS=false

# Cleanup de sesiones expiradas (requerido para /api/cleanup-sessions con POST manual)
SESSION_CLEANUP_SECRET=cambia_esto_por_un_secret_largo
# CRON_SECRET es generado automáticamente por Vercel para autenticar cron jobs
# (no hace falta setearlo manualmente en Vercel, pero sí en local si querés probar)
# CRON_SECRET=xxx
